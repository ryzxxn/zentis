{
  "name": "zentis",
  "version": "1.0.1",
  "description": "A high-level agentic framework for Model Context Protocol (MCP) with memory and LLM integration.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": {
    "child_process": false,
    "fs": false,
    "path": false,
    "os": false,
    "stream": false,
    "buffer": false,
    "events": false
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && npm run bundle",
    "bundle": "esbuild src/browser.ts --bundle --outfile=dist/zentis.bundle.js --format=iife --platform=browser --define:process.env.GROQ_API_KEY=\\\"\\\" --alias:node:process=process --alias:node:stream=stream-browserify --alias:child_process=process --alias:path=path-browserify --alias:fs=process --alias:eventsource=eventsource --alias:events=events --alias:buffer=buffer --external:pg --external:better-sqlite3 --external:util --external:net --external:tls --external:dns --external:fs --external:path --external:os",
    "demo": "tsx demo.ts",
    "chat": "tsx query.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryzxxn/zentis.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "llm",
    "zentis"
  ],
  "author": "Elton Costa",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ryzxxn/zentis/issues"
  },
  "homepage": "https://github.com/ryzxxn/zentis#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "browserify-fs": "^1.0.0",
    "buffer": "^6.0.3",
    "child_process": "^1.0.2",
    "esbuild": "^0.28.0",
    "events": "^3.3.0",
    "eventsource": "^4.1.0",
    "eventsource-polyfill": "^0.9.6",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "rimraf": "^6.1.3",
    "stream-browserify": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/client": "^2.0.0-alpha.2",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "openai": "^6.34.0",
    "pg": "^8.20.0"
  }
}
