    "model-context-protocol",
    "ai",
    "agent",
    "llm",
    "zentis"
  ],
  "author": "Elton Costa",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ryzxxn/zentis/issues"
  },
  "homepage": "https://github.com/ryzxxn/zentis#readme",
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/client": "^2.0.0-alpha.2",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "openai": "^6.34.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "type": "module"
