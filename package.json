{
  "name": "zentis",
  "version": "1.1.24",
  "description": "A high-level agentic framework for Model Context Protocol (MCP) with memory and LLM integration.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "demo": "tsx demo.ts",
